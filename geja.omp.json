{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#ffffff",
          "background": "#6c5ce7",
          "template": " {{ .PID }} "
        },
         {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#1e1e1e",
          "background": "#a29bfe",
          "properties": {
            "style": "folder"
          }
        }
      ]
    }
  ]
}